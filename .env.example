# Copy to .env.local and adjust. See src/lib/config.ts.

# "mock" = in-memory seed + local CRUD (default). "live" = real ISACS API.
NEXT_PUBLIC_DATA_SOURCE=mock

# Browser-facing API base. "/api" routes through the Next.js same-origin proxy.
NEXT_PUBLIC_ISACS_API_BASE_URL=/api

# Absolute upstream ISACS API base (server-side only).
ISACS_API_UPSTREAM_URL=https://isacs.zumalogix.com/api
